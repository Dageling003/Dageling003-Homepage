# homepage — Caddy 配置（支持 HTTPS 自动续签）
# 使用前：
#   1. pnpm build 构建所有应用
#   2. 将 {host} 替换为实际域名或 IP
#   3. 将 {email} 替换为你的邮箱（ZeroSSL 必需）
#
# ====== HTTPS / ACME ======
# 默认使用 ZeroSSL（国内可正常访问）
# 切换到 Let's Encrypt：
#   将 acme_ca 改为 https://acme-v02.api.letsencrypt.org/directory
#
# 域名 → 自动申请证书，HTTP 自动跳转 HTTPS
# IP   → 仅 HTTP（ACME 不支持 IP 签发证书）

{
    acme_ca https://acme.zerossl.com/v2/DV90
    email {email}
}

{host} {
    # ====== API 反向代理 ======
    # 使用 handle 而非 handle_path：NestJS 设了 globalPrefix 'api'，
    # 需要保留 /api 前缀转发给后端。
    handle /api/* {
        header Cache-Control "no-store, no-cache, must-revalidate"
        reverse_proxy localhost:8000
    }

    # ====== 静态资源长期缓存（Vite 哈希文件名） ======
    handle /assets/* {
        header Cache-Control "public, max-age=31536000, immutable"
        root * /var/www/homepage/frontend
        file_server
    }

    # ====== 管理后台 SPA ======
    handle_path /admin* {
        header Cache-Control "no-cache"
        root * /var/www/homepage/admin
        try_files {path} /index.html
        file_server
    }

    # ====== 上传文件（禁止执行脚本） ======
    handle_path /files/* {
        root * /var/www/homepage
        @blocked ext .php .phtml .pht .php5 .php7 .phps .cgi .pl .py .sh .asp .aspx .jsp .jspx
        respond @blocked 403
        file_server
    }

    # ====== 前台主页 SPA（根路径默认入口） ======
    # 未初始化时只显示布局/默认内容
    handle {
        header Cache-Control "no-cache"
        root * /var/www/homepage/frontend
        try_files {path} /index.html
        file_server
    }
}
