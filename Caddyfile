# homepage — Caddy 配置（HTTP，内网部署）
# 使用前：pnpm build 构建所有应用
# 修改 server_ip 为实际部署机器的内网 IP

http://192.168.31.86:80 {

    # ====== 前台主页 ======
    handle_path / {
        root * /var/www/homepage/frontend
        file_server
    }

    # ====== API 反向代理 ======
    handle_path /api/* {
        reverse_proxy localhost:8000
    }
}

# ====== 管理后台 ======
http://192.168.31.86:3001 {
    root * /var/www/homepage/admin
    file_server
}
