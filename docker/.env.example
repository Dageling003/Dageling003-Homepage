# ====================================
# homepage — Docker 部署环境变量
# 复制为 .env.docker 后修改（或运行 bash deploy.sh 自动生成）
# ====================================

# 域名或 IP（必填）
# - 域名（如 myhomepage.example.com）→ 自动申请 HTTPS 证书
# - 内网 IP（如 192.168.1.100）→ 仅 HTTP
DOMAIN=your-domain-or-ip

# JWT 密钥（必填，至少 20 位，启动时强制校验）
# 生成命令：openssl rand -base64 32
JWT_SECRET=replace-with-a-strong-random-secret

# 默认管理员密码（可选，≥ 12 位）
# 留空时：首次访问 /admin/setup 会在页面上引导你创建管理员账号（推荐）
# 不留空时：后端首次启动会自动用此密码创建 admin 账号
# 生成命令：openssl rand -base64 24
# 创建后请立即登录后台并修改密码
DEFAULT_ADMIN_PASSWORD=

# 初始化令牌（生产环境必填 —— 后端会强制校验）
# NODE_ENV=production 且数据库无用户时，若 SETUP_TOKEN 为空，容器将拒绝启动。
# 目的：防止公网部署上线到你完成初始化之间的窗口期被抢注管理员（攻击者可从
# CT log 秒级发现新证书并抢先创建 admin）。
# 设置后：/api/auth/create-first-admin 必须带 X-Setup-Token 请求头。
# 生成命令：openssl rand -hex 24
# 首次初始化完成后可从 .env 中删除（此时数据库已有用户，闸门自动放行）。
SETUP_TOKEN=

# ====================================
# ACME / HTTPS 证书配置（仅域名部署时需要）
# ====================================
# 证书颁发机构：
#   ZeroSSL（推荐）：https://acme.zerossl.com/v2/DV90（国内可正常访问）
#   Let's Encrypt：  https://acme-v02.api.letsencrypt.org/directory
ACME_CA=https://acme.zerossl.com/v2/DV90
ACME_EMAIL=your-email@example.com

# MariaDB 数据库配置（所有密码必填，无默认值兜底）
DB_ROOT_PASSWORD=your-db-root-password
DB_USERNAME=homepage
DB_PASSWORD=your-db-password
DB_DATABASE=homepage

# ====================================
# 构建镜像源（可选，国内部署推荐设置）
# 如果你的服务器无法流畅拉取 docker.io 或 gcr.io 镜像，
# 可以设置以下镜像源加速构建。
# 以 docker.1ms.run 为例（与 MARIADB_IMAGE 同源）：
#   BUILDER_IMAGE=docker.1ms.run/library/node:22-slim
#   RUNTIME_IMAGE=docker.1ms.run/gcr.io/distroless/nodejs22-debian12
# 留空则使用原始 docker.io 和 gcr.io
BUILDER_IMAGE=
RUNTIME_IMAGE=

# MariaDB 镜像源（可选，可选以下任一）
# 方案1: Docker Hub 镜像加速器（推荐）
# MARIADB_IMAGE=docker.1ms.run/library/mariadb:11.4
# 方案2: 清华大学镜像
# MARIADB_IMAGE=mirrors.tuna.tsinghua.edu.cn/library/mariadb:11.4
# 方案3: 中科大镜像
# MARIADB_IMAGE=mirrors.ustc.edu.cn/library/mariadb:11.4
# 方案4: Docker Hub 官方（需网络通畅）
# MARIADB_IMAGE=mariadb:11.4
MARIADB_IMAGE=docker.1ms.run/library/mariadb:11.4

# ====================================
# 数据库迁移（生产环境必读）
# ====================================
# DB_SYNCHRONIZE: TypeORM 自动同步 Schema（仅开发环境使用，生产环境必须为 false）
# DB_MIGRATIONS_RUN: 启动时自动执行待运行的 migration（可选，也可手动执行）
DB_SYNCHRONIZE=false
# DB_MIGRATIONS_RUN=true

# ====================================
# 找回密码 / 邮件通知（可选，不配也能用）
# ====================================
# 后台「忘记密码」流程会通过 SMTP 发送重置链接。
# 不配以下变量时，重置链接会降级输出到 docker logs，需 SSH 上去抄链接。
#
# 主流邮箱 SMTP 参考：
#   QQ 邮箱（授权码登录）：smtp.qq.com:465
#     SMTP_SECURE=true   SMTP_USER=xxxx@qq.com   SMTP_PASS=授权码
#   163 邮箱：            smtp.163.com:465
#   Gmail（需应用专用密码）：smtp.gmail.com:465
#   Outlook / Hotmail：   smtp.office365.com:587
#   企业邮箱（阿里/腾讯/华为）：smtp.exmail.qq.com:465 / smtp.feishu.cn:465
#   自建邮件服务：        mail.your-domain.com:587
#
# SMTP_HOST=smtp.qq.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=noreply@your-domain.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM="Homepage <noreply@your-domain.com>"
# SMTP_REJECT_UNAUTHORIZED=true

# 找回密码链接中域名（可选，默认取 DOMAIN）
# 重置邮件里的链接形如：${PUBLIC_ADMIN_URL}/admin/reset-password?token=...
# 不配 SMTP 时此变量不影响功能（链接只在 docker logs 输出）
# PUBLIC_ADMIN_URL=https://your-domain.com
