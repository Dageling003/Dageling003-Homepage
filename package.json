{
  "name": "dageling003-homepage",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "dev:frontend": "pnpm --filter homepage-frontend dev",
    "dev:admin": "pnpm --filter homepage-admin dev",
    "dev:backend": "pnpm --filter homepage-backend start:dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "format": "prettier --write \"**/*.{ts,vue,json,md}\"",
    "migrate:run": "pnpm --filter homepage-backend migrate:run",
    "migrate:generate": "pnpm --filter homepage-backend migrate:generate",
    "migrate:revert": "pnpm --filter homepage-backend migrate:revert"
  },
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.0.0"
  }
}
