# homepage — Caddy configuration with automatic HTTPS
# All traffic goes through Caddy on ports 80/443.
#
# Static files (frontend + admin) are served directly by Caddy.
# Only API calls are proxied to the backend app container.
#
# Environment variables (set in docker-compose.yml):
#   DOMAIN      — your domain name or IP address
#   ACME_CA     — ACME provider URL (default: ZeroSSL, works in China)
#   ACME_EMAIL  — email for ACME account (required for ZeroSSL)

{
	acme_ca {$ACME_CA:https://acme.zerossl.com/v2/DV90}
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	# ====== Global security headers ======
	# Frontend (public homepage) still needs 'unsafe-inline' on script-src
	# because index.html embeds a JSON-LD <script type="application/ld+json">
	# block for SEO. That block is developer-controlled and never renders
	# user input, but the CSP directive cannot distinguish. TODO: switch to
	# 'sha256-<hash>' after wiring vite to emit the hash at build time.
	# The /admin* handler below overrides this with a stricter policy that
	# drops 'unsafe-inline' entirely for the admin bundle.
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' https://api.iconify.design https://fonts.googleapis.com https://api.dicebear.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
		X-Frame-Options "DENY"
		-Server
	}

	# ====== Health check (for Caddy healthcheck in docker-compose) ======
	handle /health {
		reverse_proxy app:8000
	}

	# ====== API reverse proxy (backend only) ======
	# 使用 handle 而非 handle_path：NestJS 设了 globalPrefix 'api'，
	# 需要保留 /api 前缀转发给后端，否则后端匹配不到路由返回 404。
	handle /api/* {
		header Cache-Control "no-store, no-cache, must-revalidate"
		reverse_proxy app:8000
	}

	# ====== Static assets long-term cache (Vite hashed filenames) ======
	handle /assets/* {
		header Cache-Control "public, max-age=31536000, immutable"
		root * /var/www/frontend
		file_server
	}

	# ====== Admin static assets (Vite hashed filenames) ======
	# 必须在 /admin* 之前，否则 /admin/assets/* 会被 /admin* 的 try_files 吞掉返回 index.html
	# root 用 /var/www（不是 /var/www/admin）：Caddy file_server 会把完整请求路径拼到 root 后，
	# 请求路径 /admin/assets/xxx.js + root /var/www = /var/www/admin/assets/xxx.js ✓
	handle /admin/assets/* {
		header Cache-Control "public, max-age=31536000, immutable"
		root * /var/www
		file_server
	}

	# ====== Admin backend SPA ======
	# Served directly by Caddy — no intermediate Node process.
	# SEC-001: admin bundle has no inline <script> (Vite ships ES modules only),
	# so we override the global CSP with a stricter policy that removes
	# 'unsafe-inline' from script-src. style-src still needs 'unsafe-inline'
	# because ant-design-vue injects component styles at runtime via <style>.
	handle /admin* {
		header Cache-Control "no-cache"
		header Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' https://api.iconify.design; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
		root * /var/www
		try_files {path} /admin/index.html
		file_server
	}

	# ====== Uploads: strict allow-list on file extensions ======
	# SEC-005: previous blocklist missed .svg, which browsers execute as
	# active content when served as image/svg+xml. Any future upload path
	# that forgets to normalize could then plant stored XSS. Switching to
	# an allow-list of image extensions cuts that risk off at the edge.
	# The current avatar upload only writes .webp; the rest are kept for
	# forward-compat with UGC image features.
	handle /files/* {
		@allowed path *.webp *.jpg *.jpeg *.png *.gif
		root * /var/www
		# Extra hardening: uploads are static assets, never executable.
		header Content-Security-Policy "default-src 'none'"
		header X-Content-Type-Options "nosniff"
		file_server @allowed
		# Anything not on the allow-list gets a hard 403.
		respond 403
	}

	# ====== Frontend homepage SPA (default landing) ======
	# 根路径直接服务公开主页，未初始化时只显示布局/默认内容
	handle {
		header Cache-Control "no-cache"
		root * /var/www/frontend
		try_files {path} /index.html
		file_server
	}
}
