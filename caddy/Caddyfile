# homepage — Caddy configuration with automatic HTTPS
# All traffic goes through Caddy on ports 80/443.
#
# Static files (frontend + admin) are served directly by Caddy.
# Only API calls are proxied to the backend app container.
#
# Environment variables (set in docker-compose.yml):
#   DOMAIN      — your domain name or IP address
#   ACME_CA     — ACME provider URL (default: ZeroSSL, works in China)
#   ACME_EMAIL  — email for ACME account (required for ZeroSSL)

{
	acme_ca {$ACME_CA:https://acme.zerossl.com/v2/DV90}
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	# ====== Global security headers ======
	# CSP 面向 SPA 静态资源。Vue/AntD 运行时会注入 inline <style>，
	# 因此 style-src 需要 'unsafe-inline'；frontend 的 SEO JSON-LD
	# 也是 inline <script>，因此 script-src 暂保留 'unsafe-inline'
	# （下一步可通过 vite 生成 hash 收紧）。frame-ancestors 'none' 防点击劫持。
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' https://api.iconify.design https://fonts.googleapis.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
		X-Frame-Options "DENY"
		-Server
	}

	# ====== Health check (for Caddy healthcheck in docker-compose) ======
	handle /health {
		reverse_proxy app:8000
	}

	# ====== API reverse proxy (backend only) ======
	# 使用 handle 而非 handle_path：NestJS 设了 globalPrefix 'api'，
	# 需要保留 /api 前缀转发给后端，否则后端匹配不到路由返回 404。
	handle /api/* {
		header Cache-Control "no-store, no-cache, must-revalidate"
		reverse_proxy app:8000
	}

	# ====== Static assets long-term cache (Vite hashed filenames) ======
	handle /assets/* {
		header Cache-Control "public, max-age=31536000, immutable"
		root * /var/www/frontend
		file_server
	}

	# ====== Admin static assets (Vite hashed filenames) ======
	# 必须在 /admin* 之前，否则 /admin/assets/* 会被 /admin* 的 try_files 吞掉返回 index.html
	handle /admin/assets/* {
		header Cache-Control "public, max-age=31536000, immutable"
		root * /var/www/admin
		file_server
	}

	# ====== Admin backend SPA ======
	# Served directly by Caddy — no intermediate Node process
	# 注意：Caddy 2 里没有 handle_path 指令，用 handle + path 前缀匹配。
	handle /admin* {
		header Cache-Control "no-cache"
		root * /var/www/admin
		try_files {path} /index.html
		file_server
	}

	# ====== Uploads (block script execution) ======
	# 用 path 前缀匹配 + respond 黑名单，避免依赖 http.matchers.ext
	# 模块（默认 caddy 镜像不带该模块，会报 'module not registered'）。
	handle /files/* {
		root * /var/www
		@blocked path /files/*.php /files/*.phtml /files/*.pht /files/*.php5 /files/*.php7 /files/*.phps /files/*.cgi /files/*.pl /files/*.py /files/*.sh /files/*.asp /files/*.aspx /files/*.jsp /files/*.jspx
		respond @blocked 403
		file_server
	}

	# ====== Frontend homepage SPA (default landing) ======
	# 根路径直接服务公开主页，未初始化时只显示布局/默认内容
	handle {
		header Cache-Control "no-cache"
		root * /var/www/frontend
		try_files {path} /index.html
		file_server
	}
}
