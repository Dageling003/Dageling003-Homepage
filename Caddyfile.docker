# homepage — Caddy configuration with automatic HTTPS
# All traffic goes through Caddy on ports 80/443.
#
# Static files (frontend + admin) are served directly by Caddy.
# Only API calls are proxied to the backend app container.
#
# Environment variables (set in docker-compose.yml):
#   DOMAIN      — your domain name or IP address
#   ACME_CA     — ACME provider URL (default: ZeroSSL, works in China)
#   ACME_EMAIL  — email for ACME account (required for ZeroSSL)

{
	acme_ca {$ACME_CA:https://acme.zerossl.com/v2/DV90}
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	# ====== API reverse proxy (backend only) ======
	# 使用 handle 而非 handle_path：NestJS 设了 globalPrefix 'api'，
	# 需要保留 /api 前缀转发给后端，否则后端匹配不到路由返回 404。
	handle /api/* {
		reverse_proxy app:8000
	}

	# ====== Admin backend SPA ======
	# Served directly by Caddy — no intermediate Node process
	handle_path /admin* {
		root * /var/www/admin
		try_files {path} /index.html
		file_server
	}

	# ====== Frontend homepage SPA (default landing) ======
	# 根路径直接服务公开主页，未初始化时只显示布局/默认内容
	handle {
		root * /var/www/frontend
		try_files {path} /index.html
		file_server
	}
}
