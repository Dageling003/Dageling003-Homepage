# ====================================
# homepage Backend — 环境变量配置示例
# 复制此文件为 .env 后按需修改
# 切勿把真实的 .env 提交到 Git
# ====================================

# JWT 密钥（生产环境请务必使用足够强度的随机字符串，例如 openssl rand -base64 32）
# ⚠️ 启动时检查长度 >= 20 且不是默认值，否则拒绝启动
JWT_SECRET=replace-with-a-strong-random-secret

# 应用端口
PORT=8000

# ====================================
# 默认管理员账号初始化
# 首次启动且 users 表为空时，程序会读取该口令创建默认 admin 账号。
# - 留空或缺失将导致启动失败
# - 至少 12 位，推荐使用 `openssl rand -base64 24` 生成
# - 创建后请立即登录后台并修改密码
# ====================================
DEFAULT_ADMIN_PASSWORD=replace-with-a-strong-password-at-least-12-chars

# ====================================
# MariaDB 数据库配置
# 确保数据库已存在（`CREATE DATABASE `homepage`;）
# ====================================
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=replace-with-your-db-username
DB_PASSWORD=replace-with-your-db-password
DB_DATABASE=homepage

# ====================================
# 数据库 Schema 同步（仅开发环境设为 true，生产环境务必设为 false）
# ====================================
DB_SYNCHRONIZE=false

# ====================================
# CORS 允许的前端来源（多个用逗号分隔，留空使用默认 localhost）
# ====================================
# CORS_ORIGIN=http://192.168.1.100:3000,http://192.168.1.100:3001

# ====================================
# Docker 部署环境变量（docker-compose.yml 使用）
# ====================================
# DB_ROOT_PASSWORD=rootpassword
# DB_USERNAME=homepage
# DB_PASSWORD=homepage_pass
# JWT_SECRET=  (共用一个)
# DEFAULT_ADMIN_PASSWORD=  (共用一个)
